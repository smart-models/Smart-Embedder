# BGE-M3 Embedding & Reranker Server - environment overrides
# Copy this file to `.env` and adjust values. `.env` is gitignored.
# All variables are optional. When launched through start_server.bat/start_server.sh,
# selected Qwen rerank values can be auto-tuned before docker-compose.gpu.yml defaults apply.

# --- Network ------------------------------------------------------------------

# Host port to expose the server on. Change this if 8000 is already in use.
# Docker: published host port (container stays on 8000 internally).
# Local mode: the uvicorn --port passed by start_server.sh/start_server.bat.
PORT=8000

# --- Model / inference --------------------------------------------------------

# Max input tokens per sequence. BGE-M3 supports up to 8192 but VRAM scales
# quadratically with length. Default tuned for RTX 4060 8GB.
MAX_INPUT_LENGTH=2048

# Dense embedding model selected by start_server.bat/start_server.sh.
# The launcher prompts for BGE or QWEN and sets this automatically.
# Defensive default: BAAI/bge-m3
# DENSE_EMBEDDING_MODEL=BAAI/bge-m3

# Reranker model id selected by start_server.bat/start_server.sh.
# The launcher prompts for BGE or QWEN and sets this automatically.
# Defensive default: BAAI/bge-reranker-v2-m3
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Max token length used by Qwen/Qwen3-Reranker-0.6B CausalLM scoring.
# Applies only when QWEN is selected at startup.
# Leave unset in your shell/.env to let the launcher tune this from GPU VRAM.
# QWEN_RERANK_MAX_LENGTH=8192

# Max query-passage pairs per Qwen reranker micro-batch.
# Lower this on small GPUs to reduce peak VRAM; raise it only after benchmarking.
# Leave unset in your shell/.env to let the launcher tune this from GPU VRAM.
# QWEN_RERANK_BATCH_SIZE=16

# Global HTTP request timeout (seconds). Keep above RERANK_GPU_TIMEOUT.
REQUEST_TIMEOUT=90

# --- Payload limits -----------------------------------------------------------

# Max items and total text accepted per embedding request.
MAX_SENTENCES_PER_REQUEST=128
MAX_SENTENCE_CHARS=20000
MAX_TOTAL_CHARS_PER_REQUEST=250000

# Max items and total text accepted per rerank request.
MAX_RERANK_PASSAGES=128
MAX_RERANK_TEXT_CHARS=20000
MAX_RERANK_TOTAL_CHARS=250000

# Docker named volume for the Hugging Face cache.
HF_MODEL_CACHE_VOLUME=smart-embedder-hf-cache

# --- Authentication -----------------------------------------------------------

# Bearer token for API access. Leave empty to disable authentication.
# When set, all non-public endpoints require: Authorization: Bearer <token>.
# /health, /stats, /metrics, /docs, /redoc, and /openapi.json stay public.
API_TOKEN=

# --- Backpressure / rate limiting --------------------------------------------

# Max queued requests before HTTP 503. Raise on bursty traffic with deep queues.
MAX_QUEUE_SIZE=200

# Max concurrent /rerank slots before HTTP 503. The reranker uses a single-worker
# executor; this bounds queued HTTP tasks waiting for the GPU.
RERANK_MAX_QUEUE=32

# Hard GPU timeout (seconds) for a single rerank inference. Must stay strictly
# below REQUEST_TIMEOUT so the executor cancels before the HTTP layer 504s.
RERANK_GPU_TIMEOUT=60

# Rate limit per client IP (token-bucket refill rate, requests/minute).
# Tuned default: 60 req/s, 2x measured peak on RTX 4060 8GB.
RATE_LIMIT_REQUESTS_PER_MINUTE=3600

# Token bucket capacity. Allows short bursts above the per-minute rate.
# 120 is about 2s of full-throttle traffic at the default rate.
RATE_LIMIT_BURST_SIZE=120
